# Matrix Hookshot - Environment Variables Template
#
# Copy this file to .env and fill in your actual values
# These variables are used by config.railway.yml
#
# Generate tokens with: openssl rand -base64 32

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Matrix homeserver domain (e.g., matrix.org, example.com)
MATRIX_DOMAIN=matrix.org

# Matrix homeserver URL (must be publicly accessible)
MATRIX_URL=https://matrix.org

# Hookshot Matrix user ID
MATRIX_USER_ID=@hookshot:matrix.org

# Authentication tokens (generate with: openssl rand -base64 32)
MATRIX_AS_TOKEN=your_as_token_here
MATRIX_HS_TOKEN=your_hs_token_here

# =============================================================================
# RAILWAY-SPECIFIC URLS
# =============================================================================

# Webhook endpoint prefix (replace with your Railway app URL)
WEBHOOK_URL_PREFIX=https://your-app.railway.app/webhook/

# Widget endpoint public URL
WIDGET_PUBLIC_URL=https://your-app.railway.app/widgetapi/v1/static/

# =============================================================================
# BRIDGE CONFIGURATION
# =============================================================================

# Port where the bridge listens (usually 9993)
BRIDGE_PORT=9993

# Bind address (0.0.0.0 for Railway)
BRIDGE_BIND_ADDRESS=0.0.0.0

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Colorize logs in output
LOG_COLORIZE=false

# =============================================================================
# WIDGETS
# =============================================================================

# Widget title shown to users
WIDGET_TITLE=Hookshot Configuration

# =============================================================================
# INTEGRATIONS - OPTIONAL
# =============================================================================

# Generic webhook support
GENERIC_ENABLED=true
GENERIC_JS_TRANSFORMS=true
GENERIC_WAIT_COMPLETE=true

# GitHub integration (requires OAuth setup)
GITHUB_ENABLED=false

# GitLab integration (requires OAuth setup)
GITLAB_ENABLED=false

# JIRA integration
JIRA_ENABLED=false

# Figma integration
FIGMA_ENABLED=false

# OpenProject integration
OPENPROJECT_ENABLED=false

# =============================================================================
# OPTIONAL: ADVANCED
# =============================================================================

# Media encryption URL (optional)
MEDIA_ENCRYPTION_URL=

# Redis cache URI (optional, for distributed deployments)
# REDIS_URI=redis://localhost:6379

# Database configuration (optional)
# DB_ENGINE=sqlite
# DB_CONNECTION_STRING=

# Webhook security
# FEEDS_REQUIRE_SECURE=true

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================

# Node.js environment
NODE_ENV=production
