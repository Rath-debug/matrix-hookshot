{
  "name": "matrix-hookshot",
  "description": "A bridge between Matrix and multiple project management services",
  "volumes": {
    "/data": "matrix-hookshot-data"
  },
  "ports": [
    {
      "containerPort": 9993,
      "name": "bridge"
    },
    {
      "containerPort": 7775,
      "name": "metrics"
    }
  ],
  "environmentVariables": {
    "NODE_ENV": "production",
    "LOG_LEVEL": "info",
    "LOG_COLORIZE": "false"
  }
}
