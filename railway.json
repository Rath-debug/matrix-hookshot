{
  "name": "matrix-hookshot",
  "description": "A bridge between Matrix and multiple project management services",
  "volumes": {
    "/data": "matrix-hookshot-data"
  },
  "ports": [
    {
      "containerPort": 9000,
      "name": "appservice"
    },
    {
      "containerPort": 9001,
      "name": "metrics"
    },
    {
      "containerPort": 9002,
      "name": "widgets"
    }
  ],
  "environmentVariables": {
    "NODE_ENV": "production",
    "LOG_LEVEL": "info",
    "LOG_COLORIZE": "false"
  }
}
